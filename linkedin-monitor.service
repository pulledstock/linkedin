[Unit]
Description=LinkedIn Job Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/linkedin
ExecStart=/home/YOUR_USER/linkedin/venv/bin/python monitor.py
Restart=on-failure
RestartSec=60

[Install]
WantedBy=multi-user.target
